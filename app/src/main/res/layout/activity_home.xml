<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_loginregist">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#A06E7E"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/white_notif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/dongle_bold"
            android:gravity="center"
            android:text="BioTech Seminar Hub"
            android:textColor="@android:color/white"
            android:textSize="35sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/tvHelloUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:fontFamily="@font/dongle_bold"
                android:text="Hello, User!"
                android:textColor="#A06E7E"
                android:textSize="40sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_loginregist"
                android:drawablePadding="10dp"
                android:drawableStart="@drawable/ic_search"
                android:fontFamily="@font/dongle_bold"
                android:hint="Search..."
                android:paddingHorizontal="20dp"
                android:textSize="25sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#E9F5E9"
                app:cardCornerRadius="25dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="47dp"
                        android:layout_height="47dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_funfact" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dongle_bold"
                            android:includeFontPadding="false"
                            android:text="Facts About BioTech"
                            android:textColor="#3D563D"
                            android:textSize="40sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dongle_bold"
                            android:includeFontPadding="false"
                            android:lineSpacingExtra="-8dp"
                            android:text="🌱 The Original Programmer: Did you know that DNA is essentially a complex biological code? It stores data just like a hard drive, but with a capacity far beyond any silicon chip!"
                            android:textColor="#3D563D"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:fontFamily="@font/dongle_bold"
                            android:text="See More"
                            android:textColor="#A06E7E"
                            android:textSize="24sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dongle_bold"
                        android:text="Seminar This Week"
                        android:textColor="#3D563D"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_gradient_card"
                        android:fontFamily="@font/dongle_bold"
                        android:gravity="center"
                        android:lineSpacingExtra="-10dp"
                        android:padding="8dp"
                        android:text="Bio-Code: The Intersection of Bioinformatics and Plant Genetic Engineering"
                        android:textColor="#A06E7E"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_gradient_card"
                        android:fontFamily="@font/dongle_bold"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Automated Flora: Developing Real-Time Monitoring Apps using Android &amp; Java"
                        android:textColor="#A06E7E"
                        android:textSize="18sp"
                        android:lineSpacingExtra="-10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/dongle_bold"
                        android:text="See More"
                        android:textColor="#A06E7E"
                        android:textSize="20sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnGoToRegister"
                        android:layout_width="274dp"
                        android:layout_height="57dp"
                        android:layout_marginTop="15dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_grad_button"
                        android:fontFamily="@font/dongle_bold"
                        android:text="Register Here!"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="40sp"
                        android:includeFontPadding="false"
                        android:gravity="center"
                        android:paddingBottom="5dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="327dp"
        android:layout_height="56dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="29dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home_green" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="29dp"
            android:layout_weight="1"
            android:src="@drawable/ic_calender" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="29dp"
            android:layout_weight="1"
            android:src="@drawable/ic_list" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="29dp"
            android:layout_weight="1"
            android:src="@drawable/ic_profile" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>